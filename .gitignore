node_modules/
.env
.env.local
*.log
.DS_Store
.secrets/
.claude/
core-sync.json
public/uploads/
node/public/uploads/

.claude/settings.local.json

# Local scratch / session artifacts — never commit
.tmp/
tmp/

# Video ecosystem — versionar SOLO el código fuente (src, scripts, docs, manifests
# JSON). Ignorar lo pesado/regenerable. Regenerar media con:
#   npm --prefix video install
#   node video/scripts/fetch-bank.js            # banco de imágenes (Pexels)
#   node video/scripts/generate-audio.js ...    # audio TTS (ElevenLabs)
video/node_modules/
video/out/
video/**/*.mp4
video/**/*.ogg
video/**/*.mp3
video/**/*.wav
video/public/images/**/*.jpg
video/public/images/**/*.jpeg
video/public/images/**/*.png

# Call PDFs (250 MB) and their text extracts (20 MB) — regenerated by:
#   node scripts/fetch-call-pdfs.js
#   node scripts/extract-call-text.js
data/call_pdfs/
data/call_extracts/

# LLM-structured extracts (small, but regenerable from extracts with API cost ~$5):
#   node scripts/structure-call.js
# Per-call vector embeddings (~500 MB total, regenerable ~$0.50):
#   node scripts/embed-calls.js
data/call_structured/
data/call_vectors/

# Admin curation state — per-environment (local and VPS keep their own).
# Copy by scp if you want to migrate the admin's review work.
data/call_curation.json

# Academy media (vídeos >100MB, no caben en GitHub; se despliegan aparte)
public/academy-media/*.mp4
