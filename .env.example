# ── Database ──────────────────────────────────
DB_HOST=wordpress-eufunding-db-1
DB_PORT=3306
DB_USER=root
DB_PASS=changeme
DB_NAME=eplus_tools

# ── Auth ──────────────────────────────────────
JWT_SECRET=changeme-use-a-64-char-random-string
JWT_REFRESH_SECRET=changeme-use-another-64-char-random-string

# ── Server ────────────────────────────────────
PORT=3000
NODE_ENV=production
# Single primary origin (back-compat). Prefer CORS_ORIGINS for multi-origin.
CORS_ORIGIN=https://intake.eufundingschool.com
# Comma-separated allow-list of origins permitted to call the API.
# If unset, the server falls back to the defaults defined in server.js
# (localhost + eufundingschool.test/.com + intake./app.).
# CORS_ORIGINS=https://eufundingschool.com,https://app.eufundingschool.com

# ── Google OAuth (legacy, login directo — en desuso con OIDC) ──
GOOGLE_CLIENT_ID=

# ── OIDC / Login único (Authentik) ────────────
# El SaaS delega el login en Authentik (login.eufundingschool.com).
# El secret se configura en Coolify (prod) / .env local (dev), NUNCA en el repo.
OIDC_ISSUER=https://login.eufundingschool.com/application/o/intake/
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
# Opcional. Por defecto = APP_URL + /v1/auth/oidc/callback
# Prod: https://intake.eufundingschool.com/v1/auth/oidc/callback
# Dev:  http://localhost:3000/v1/auth/oidc/callback
# OIDC_REDIRECT_URI=
APP_URL=https://intake.eufundingschool.com

# ── GoHighLevel / centralize.es CRM + email (Fase 4 sync) ────
# Leave blank to disable: subscribers will still be captured locally,
# but no contact will be pushed to GHL. Useful for dev.
# Get the Private Integration token from your GHL/centralize panel:
#   Settings → Business Profile → Private Integrations → New
# Or for centralize white-label: ask their support if not visible.
GHL_API_KEY=
# Find this in the URL of your sub-account: /v2/location/<LOCATION_ID>/...
GHL_LOCATION_ID=
# Both white-label and official GHL share the same backend.
# Override only if your provider uses a different endpoint.
GHL_API_BASE=https://services.leadconnectorhq.com
# Optional: API version header (default 2021-07-28 — current as of 2026).
# GHL_API_VERSION=2021-07-28
# Set to 'true' to force-disable sync even if the keys are filled.
# GHL_DISABLED=false
